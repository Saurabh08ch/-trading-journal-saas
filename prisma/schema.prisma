generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Instrument {
  NIFTY
  BANKNIFTY
  CRYPTO
  STOCKS
}

enum TradeOutcome {
  WIN
  LOSS
  BREAKEVEN
}

enum TradeType {
  BUY
  SELL
}

enum Emotion {
  FEAR
  FOMO
  REVENGE_TRADING
  CONFIDENCE
  DISCIPLINE
}


model User {
 
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")

  accounts      Account[]
  sessions      Session[]
  trades        Trade[]
  monthlySnapshots MonthlySnapshot[]
  publicReports PublicReport[]
  mentorStudents MentorStudent[] @relation("MentorStudentMentor")
  studentMentors MentorStudent[] @relation("MentorStudentStudent")
  tradeCommentsAuthored TradeComment[] @relation("TradeCommentMentor")

  @@map("users")
}


model Trade {
  id            String       @id @default(cuid())
  userId        String       @map("user_id")
  date          DateTime
  instrument    Instrument
  tradeType     TradeType    @default(BUY) @map("trade_type")
  strategy      String
  entryPrice    Decimal      @map("entry_price") @db.Decimal(18, 4)
  exitPrice     Decimal      @map("exit_price") @db.Decimal(18, 4)
  stopLoss      Decimal      @map("stop_loss") @db.Decimal(18, 4)
  riskPercent   Decimal      @map("risk_percent") @db.Decimal(6, 2)
  positionSize  Decimal      @map("position_size") @db.Decimal(18, 4)
  pnl           Decimal      @db.Decimal(18, 2)
  rrRatio       Decimal      @map("rr_ratio") @db.Decimal(10, 2)
  outcome       TradeOutcome
  emotion       Emotion
  notes         String?      @db.Text
  screenshotUrl String?      @map("screenshot_url")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments      TradeComment[]

  @@index([userId, date])
  @@map("trades")
}

model MonthlySnapshot {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  month       Int
  year        Int
  totalTrades Int      @map("total_trades")
  winRate     Float    @map("win_rate")
  totalProfit Float    @map("total_profit")
  avgRR       Float    @map("avg_rr")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId, year, month])
  @@map("monthly_snapshots")
}

model PublicReport {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  month     String
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, month])
  @@index([isPublic])
  @@map("public_reports")
}

model MentorStudent {
  id        String   @id @default(cuid())
  mentorId  String   @map("mentor_id")
  studentId String   @map("student_id")
  mentor    User     @relation("MentorStudentMentor", fields: [mentorId], references: [id], onDelete: Cascade)
  student   User     @relation("MentorStudentStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([mentorId, studentId])
  @@index([mentorId])
  @@index([studentId])
  @@map("mentor_students")
}

model TradeComment {
  id        String   @id @default(cuid())
  tradeId   String   @map("trade_id")
  mentorId  String   @map("mentor_id")
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  trade      Trade   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  mentor     User    @relation("TradeCommentMentor", fields: [mentorId], references: [id], onDelete: Cascade)

  @@index([tradeId, createdAt])
  @@index([mentorId])
  @@map("trade_comments")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
